# Copy to .env and adjust. Never commit real secrets.

# --- Datastores (match infra/docker-compose.yml) ---
DATABASE_URL=postgres://civa:civa@localhost:5432/civa
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=dev-only-change-me
JWT_ISSUER=civa
ACCESS_TOKEN_TTL=900            # seconds
REFRESH_TOKEN_TTL=2592000       # seconds (30d)

# --- LiveKit (dev defaults from docker-compose) ---
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# --- TTS gateway / ml-box worker contract ---
# The local Silero worker (D:\dev\leaders\ml-box) authenticates with this bearer token.
ML_BOX_TOKEN=dev-tts-token
TTS_STORE_DIR=./infra/tts-store

# --- Ports (defaults; each service reads its own) ---
GATEWAY_PORT=8080
AUTH_PORT=8081
LOBBY_PORT=8082
ENGINE_PORT=8083
TRADE_PORT=8084
DIPLOMACY_PORT=8085
ASSEMBLY_PORT=8086
TTS_GATEWAY_PORT=8087
