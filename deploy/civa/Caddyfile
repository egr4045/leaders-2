# CIVA gateway (launcher origin), inside the `web` container on :8088. One origin fronts the SPA,
# shared auth, the orchestrator, and the on-demand game lobby — all reached over `civa-net`.
{
	admin off
	auto_https off
}

:8088 {
	encode gzip

	# Shared auth (client calls /auth/login on the same origin).
	handle /auth/* {
		reverse_proxy auth:8081
	}

	# Orchestrator API: /orchestrator/games, /orchestrator/games/:id/enter (prefix stripped).
	handle_path /orchestrator/* {
		reverse_proxy orchestrator:8090
	}

	# Game lobby (Socket.io). Started on demand — 502s until the orchestrator brings it up.
	handle /socket.io/* {
		reverse_proxy lobby:8082
	}

	# SPA static with history fallback.
	handle {
		root * /srv/www
		try_files {path} /index.html
		file_server
	}
}
